<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no">
  <title>Viáticos · M Dreieck</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <style>
    :root {
      --bg:#0e0e1a; --surface:#1a1a2e; --card:#16213e;
      --accent:#4a90d9; --accent2:#e8a838;
      --text:#e8e8f0; --muted:#8888aa; --border:#2a2a4a;
      --success:#2ecc71; --danger:#e74c3c; --input-bg:#0e0e1a;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:80px;}
    header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 16px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:100;}
    header h1{font-size:16px;font-weight:700;}
    header p{font-size:11px;color:var(--muted);}
    .logo{width:38px;height:38px;background:#1a1080;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:#fff;letter-spacing:-1px;flex-shrink:0;}
    main{padding:16px;max-width:520px;margin:0 auto;}
    .card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:14px;}
    .card-title{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--accent);margin-bottom:14px;}
    label{display:block;font-size:12px;color:var(--muted);margin-bottom:4px;margin-top:12px;}
    label:first-of-type{margin-top:0;}
    input,select,textarea{width:100%;background:var(--input-bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:14px;padding:10px 12px;outline:none;transition:border-color .15s;-webkit-appearance:none;font-family:inherit;}
    textarea{resize:vertical;min-height:70px;}
    input:focus,select:focus,textarea:focus{border-color:var(--accent);}
    select option{background:var(--card);}
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}

    .note{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.4;padding:6px 10px;background:rgba(232,168,56,.08);border-left:3px solid var(--accent2);border-radius:4px;}
    .note.info{border-left-color:var(--accent);background:rgba(74,144,217,.08);}

    .btn-ruta{width:100%;margin-top:12px;padding:12px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity .15s;}
    .btn-ruta:active{opacity:.8;}
    .btn-ruta:disabled{opacity:.5;cursor:not-allowed;}

    .btn-maps{width:100%;margin-top:8px;padding:11px;background:transparent;border:1px solid #34a853;color:#34a853;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;display:none;align-items:center;justify-content:center;gap:8px;text-decoration:none;}
    .btn-maps.show{display:flex;}
    .btn-waze{width:100%;margin-top:8px;padding:11px;background:transparent;border:1px solid #33ccff;color:#33ccff;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;display:none;align-items:center;justify-content:center;gap:8px;text-decoration:none;}
    .btn-waze.show{display:flex;}

    .ruta-result{display:none;margin-top:12px;background:var(--bg);border:1px solid var(--accent);border-radius:10px;padding:12px 14px;}
    .ruta-result.show{display:block;}
    .ruta-stat{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border);}
    .ruta-stat:last-child{border-bottom:none;}
    .ruta-stat span:first-child{font-size:12px;color:var(--muted);}
    .ruta-stat span:last-child{font-size:15px;font-weight:700;color:var(--accent2);}

    .concepto{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
    .concepto:last-child{border-bottom:none;}
    .concepto-info{flex:1;}
    .concepto-label{font-size:13px;font-weight:600;}
    .concepto-desc{font-size:11px;color:var(--muted);margin-top:2px;}
    .concepto-monto{font-size:15px;font-weight:700;color:var(--accent2);text-align:right;min-width:100px;}

    .total-box{background:linear-gradient(135deg,#1a2a4a,#1a3a2a);border:1px solid var(--accent);border-radius:14px;padding:20px 16px;margin-bottom:14px;text-align:center;}
    .total-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;}
    .total-monto{font-size:36px;font-weight:800;color:var(--success);margin:6px 0;}
    .total-sub{font-size:13px;color:var(--muted);}

    .btn-guardar,.btn-pdf,.btn-email{width:100%;padding:15px;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;transition:opacity .15s;margin-bottom:10px;}
    .btn-guardar{background:var(--success);color:#fff;}
    .btn-pdf{background:#c0392b;color:#fff;}
    .btn-email{background:#8e44ad;color:#fff;}
    .btn-guardar:active,.btn-pdf:active,.btn-email:active{opacity:.8;}
    .btn-guardar:disabled,.btn-pdf:disabled,.btn-email:disabled{opacity:.5;cursor:not-allowed;}

    #toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 20px;font-size:14px;font-weight:600;transition:transform .3s ease;z-index:999;white-space:nowrap;}
    #toast.show{transform:translateX(-50%) translateY(0);}
    #toast.ok{border-color:var(--success);color:var(--success);}
    #toast.err{border-color:var(--danger);color:var(--danger);}

    .spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:none;}
    .spinner.show{display:inline-block;}
    @keyframes spin{to{transform:rotate(360deg);}}

    .error-msg{font-size:12px;color:var(--danger);margin-top:6px;display:none;}

    .nav-bottom{display:flex;justify-content:space-between;padding:12px 16px;background:var(--surface);border-top:1px solid var(--border);position:fixed;bottom:0;left:0;right:0;}
    .nav-bottom a{color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px;}

    /* Uber/Taxi rows */
    .transporte-item{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px;margin-top:10px;}
    .transporte-item label{margin-top:8px;}
    .transporte-item label:first-of-type{margin-top:0;}
  </style>
</head>
<body>

<header>
  <div class="logo">MD</div>
  <div>
    <h1>Calculadora de Viáticos</h1>
    <p>M Dreieck S.A. de C.V.</p>
  </div>
</header>

<main>

  <!-- ① DATOS DEL SOLICITANTE -->
  <div class="card">
    <div class="card-title">👤 Datos del solicitante</div>
    <label>Área solicitante</label>
    <input type="text" id="area" placeholder="Ej: Infraestructura">
    <label>Nombre de quien solicita</label>
    <input type="text" id="solicitante" placeholder="Nombre completo">
    <label>Nombre completo del trabajador (a quien se depositarán los viáticos)</label>
    <input type="text" id="trabajador" placeholder="Nombre completo">
    <div class="row2">
      <div>
        <label>Fecha inicio del viaje</label>
        <input type="date" id="fechaInicio">
      </div>
      <div>
        <label>Fecha fin del viaje</label>
        <input type="date" id="fechaFin">
      </div>
    </div>
    <label>Tipo de servicio / motivo del viaje</label>
    <input type="text" id="tipoServicio" placeholder="Ej: Cambio de tarjetas en equipos de alertamiento">
    <label>Nombre del cliente</label>
    <input type="text" id="cliente" placeholder="Ej: Municipio de Puebla">
    <label>Observaciones</label>
    <textarea id="observaciones" placeholder="Ej: Acudirán 3 personas, área de sistemas y laboratorio"></textarea>
  </div>

  <!-- ② DATOS BANCARIOS -->
  <div class="card">
    <div class="card-title">🏦 Datos bancarios del trabajador</div>
    <div class="row2">
      <div>
        <label>Banco</label>
        <input type="text" id="banco" placeholder="Ej: Efecticard">
      </div>
      <div>
        <label>Sucursal</label>
        <input type="text" id="sucursal" placeholder="Opcional">
      </div>
    </div>
    <label>No. de tarjeta</label>
    <input type="text" id="tarjeta" placeholder="16 dígitos" maxlength="19">
    <label>Cuenta CLABE interbancaria</label>
    <input type="text" id="clabe" placeholder="18 dígitos" maxlength="18">
  </div>

  <!-- ③ RUTA -->
  <div class="card">
    <div class="card-title">🗺️ Ruta y distancia</div>
    <label>Ciudad / dirección de origen</label>
    <input type="text" id="origen" placeholder="Ej: Ciudad de México, CDMX">
    <label>Ciudad / dirección de destino</label>
    <input type="text" id="destino" placeholder="Ej: Puebla, Puebla">
    <div class="row2" style="margin-top:12px">
      <div>
        <label>Rendimiento del vehículo (km/L)</label>
        <input type="number" id="rendimiento" value="12" min="1" max="50" step="0.5">
      </div>
      <div>
        <label>Precio gasolina ($/L)</label>
        <input type="number" id="precioGas" value="24.50" min="1" step="0.01">
      </div>
    </div>
    <p class="note info" style="margin-top:10px">⚠️ Gasolina debe pagarse con tarjeta de débito o crédito. No se reconocen pagos en efectivo.</p>

    <button class="btn-ruta" id="btnRuta" onclick="calcularRuta()">
      <span class="spinner" id="spinnerRuta"></span>
      <span id="btnRutaText">📍 Calcular ruta automáticamente</span>
    </button>
    <div class="error-msg" id="errRuta"></div>

    <a class="btn-maps" id="btnMaps" href="#" target="_blank">🗺️ Ver ruta en Google Maps · consulta casetas</a>
    <a class="btn-waze" id="btnWaze" href="#" target="_blank">🚗 Ver ruta en Waze · muestra costo de casetas</a>

    <div class="ruta-result" id="rutaResult">
      <div class="ruta-stat"><span>📏 Distancia (ida)</span><span id="resKm">—</span></div>
      <div class="ruta-stat"><span>🕐 Tiempo estimado (ida)</span><span id="resTiempo">—</span></div>
      <div class="ruta-stat"><span>⛽ Litros necesarios (ida y vuelta)</span><span id="resLitros">—</span></div>
      <div class="ruta-stat"><span>💰 Costo gasolina (ida y vuelta)</span><span id="resCostoGas">—</span></div>
    </div>
  </div>

  <!-- ④ CASETAS -->
  <div class="card">
    <div class="card-title">🛣️ Casetas</div>
    <p class="note" style="margin-bottom:12px">Consulta el número de casetas y su costo en Waze o Google Maps con los botones de arriba.</p>
    <div class="row2">
      <div>
        <label>Número de casetas (ida)</label>
        <input type="number" id="numCasetas" value="0" min="0" oninput="recalcular()">
      </div>
      <div>
        <label>Precio promedio por caseta ($)</label>
        <input type="number" id="precioCaseta" value="0" min="0" step="10" oninput="recalcular()">
      </div>
    </div>
    <p class="note info" style="margin-top:8px">El total se multiplica × 2 (ida y vuelta) automáticamente.</p>
  </div>

  <!-- ⑤ DATOS DEL VIAJE -->
  <div class="card">
    <div class="card-title">👥 Datos del viaje</div>
    <div class="row2">
      <div>
        <label>Número de personas</label>
        <input type="number" id="personas" value="1" min="1" max="50" oninput="recalcular()">
      </div>
      <div>
        <label>Número de días</label>
        <input type="number" id="dias" value="1" min="1" max="30" oninput="recalcular()">
      </div>
    </div>
  </div>

  <!-- ⑥ ALIMENTACIÓN -->
  <div class="card">
    <div class="card-title">🍽️ Alimentación (por persona / día)</div>
    <p class="note" style="margin-bottom:12px">Monto estándar $250/persona. Se analizará si el gasto es <b>deducible</b> (con factura) o <b>no deducible</b> (sin factura) al momento de la comprobación.</p>
    <div class="row3">
      <div>
        <label>Desayuno ($/persona)</label>
        <input type="number" id="desayuno" value="250" min="0" oninput="recalcular()">
      </div>
      <div>
        <label>Comida ($/persona)</label>
        <input type="number" id="comida" value="250" min="0" oninput="recalcular()">
      </div>
      <div>
        <label>Cena ($/persona)</label>
        <input type="number" id="cena" value="250" min="0" oninput="recalcular()">
      </div>
    </div>
  </div>

  <!-- ⑦ HOSPEDAJE -->
  <div class="card">
    <div class="card-title">🏨 Hospedaje</div>
    <p class="note" style="margin-bottom:12px">Rango permitido: <b>$900 mínimo – $1,100 máximo</b> por persona/noche. Especificar en factura: días, noches y número de personas.</p>
    <div class="row2">
      <div>
        <label>Costo por persona/noche ($)</label>
        <input type="number" id="hospedaje" value="900" min="900" max="1100" step="50" oninput="validarHospedaje(); recalcular()">
      </div>
      <div>
        <label>Noches (días - 1 automático)</label>
        <input type="number" id="noches" value="0" min="0" readonly style="opacity:.6;cursor:not-allowed;">
      </div>
    </div>
    <div class="error-msg" id="errHosp">El hospedaje debe estar entre $900 y $1,100 por persona/noche.</div>
  </div>

  <!-- ⑧ TRANSPORTE LOCAL -->
  <div class="card">
    <div class="card-title">🚕 Transporte local (Uber / Taxi)</div>
    <p class="note" style="margin-bottom:12px">Especifica el motivo del uso en la factura o comprobante.</p>

    <div id="transporteContainer"></div>
    <button onclick="agregarTransporte()" style="width:100%;margin-top:10px;padding:10px;background:transparent;border:1px dashed var(--accent);color:var(--accent);border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">
      + Agregar Uber / Taxi
    </button>
  </div>

  <!-- ⑨ EXTRAS -->
  <div class="card">
    <div class="card-title">📋 Otros gastos</div>
    <label>Estacionamiento ($/día)</label>
    <input type="number" id="estacionamiento" value="0" min="0" oninput="recalcular()">
    <label>Imprevistos / varios ($/día)</label>
    <input type="number" id="imprevistos" value="0" min="0" oninput="recalcular()">
    <p class="note" style="margin-top:8px">Especifica el motivo de cualquier otro gasto al momento de comprobar.</p>
  </div>

  <!-- ⑩ DESGLOSE -->
  <div class="card">
    <div class="card-title">📊 Desglose total</div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">⛽ Gasolina</div>
        <div class="concepto-desc" id="descGas">Calcula la ruta primero</div>
      </div>
      <div class="concepto-monto" id="montoGas">$—</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">🛣️ Casetas</div>
        <div class="concepto-desc" id="descCasetas">—</div>
      </div>
      <div class="concepto-monto" id="montoCasetas">$0.00</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">🍽️ Alimentación</div>
        <div class="concepto-desc" id="descAlim">—</div>
      </div>
      <div class="concepto-monto" id="montoAlim">$—</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">🏨 Hospedaje</div>
        <div class="concepto-desc" id="descHospDesg">—</div>
      </div>
      <div class="concepto-monto" id="montoHosp">$—</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">🚕 Transporte local</div>
        <div class="concepto-desc" id="descTransporte">—</div>
      </div>
      <div class="concepto-monto" id="montoTransporte">$0.00</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">🚗 Estacionamiento</div>
        <div class="concepto-desc" id="descEst">—</div>
      </div>
      <div class="concepto-monto" id="montoEst">$0.00</div>
    </div>
    <div class="concepto">
      <div class="concepto-info">
        <div class="concepto-label">📋 Imprevistos</div>
        <div class="concepto-desc" id="descImp">—</div>
      </div>
      <div class="concepto-monto" id="montoImp">$0.00</div>
    </div>
  </div>

  <!-- ⑪ TOTAL -->
  <div class="total-box">
    <div class="total-label">Total a dispersar</div>
    <div class="total-monto" id="totalGeneral">$—</div>
    <div class="total-sub" id="totalPorPersona"></div>
  </div>

  <!-- ⑫ CORREO Y ACCIONES -->
  <div class="card">
    <div class="card-title">📧 Envío y registro</div>
    <label>Correo destino (a quien se envía)</label>
    <input type="email" id="correoDestino" placeholder="ejemplo@correo.com">
    <p style="font-size:11px;color:var(--muted);margin-top:4px">Con copia automática a mariel-robles@mdreieck.com.mx</p>
    <div style="margin-top:16px">
      <button class="btn-pdf" onclick="generarPDF()">📄 Generar PDF</button>
      <button class="btn-email" id="btnEmail" onclick="enviarCorreo()">📧 Generar PDF y enviar por correo</button>
      <button class="btn-guardar" id="btnGuardar" onclick="guardarEnSheets()">✅ Guardar en Google Sheets</button>
    </div>
  </div>

</main>

<div class="nav-bottom">
  <a href="index.html">← Inicio</a>
  <a href="viaticos.html" style="color:var(--accent)">🗺️ Viáticos</a>
</div>
<div id="toast"></div>

<script>
  const ORS_KEY    = 'eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjM4OWUyMjcwN2U5ZTQwNTlhOTFlMjUzMDk0YjhhM2VlIiwiaCI6Im11cm11cjY0In0=';
  const SHEETS_URL = 'https://script.google.com/macros/s/AKfycbwVRzTg4kIgo59xUdlZuC2KKyC4-q_72mWTGxFKtdiXkSz3DCIG0XJN-hQKm4lAYrrPVQ/exec';
  const REMITENTE  = 'mariel-robles@mdreieck.com.mx';

  let kmCalculados = 0, costoGasCalc = 0, transporteCount = 0;

  // ── GEOCODE ──────────────────────────────────────────────
  async function geocode(lugar) {
    const url = `https://api.openrouteservice.org/geocode/search?api_key=${ORS_KEY}&text=${encodeURIComponent(lugar)}&boundary.country=MX&size=1`;
    const r = await fetch(url);
    if (!r.ok) throw new Error('Geocode error');
    const d = await r.json();
    if (!d.features || !d.features.length) throw new Error('Lugar no encontrado: ' + lugar);
    return d.features[0].geometry.coordinates;
  }

  // ── CALCULAR RUTA ────────────────────────────────────────
  async function calcularRuta() {
    const origen  = document.getElementById('origen').value.trim();
    const destino = document.getElementById('destino').value.trim();
    const errEl   = document.getElementById('errRuta');
    if (!origen || !destino) { errEl.style.display='block'; errEl.textContent='Escribe origen y destino.'; return; }
    errEl.style.display = 'none';
    document.getElementById('btnRuta').disabled = true;
    document.getElementById('spinnerRuta').classList.add('show');
    document.getElementById('btnRutaText').textContent = 'Calculando…';
    document.getElementById('rutaResult').classList.remove('show');
    document.getElementById('btnMaps').classList.remove('show');
    document.getElementById('btnWaze').classList.remove('show');
    try {
      const [cO, cD] = await Promise.all([geocode(origen), geocode(destino)]);
      const r = await fetch('https://api.openrouteservice.org/v2/directions/driving-car/json', {
        method:'POST',
        headers:{'Authorization':ORS_KEY,'Content-Type':'application/json'},
        body: JSON.stringify({coordinates:[cO,cD],units:'km',language:'es'})
      });
      if (!r.ok) throw new Error('Error de ruta');
      const data    = await r.json();
      const summary = data.routes[0].summary;
      const km      = Math.round(summary.distance);
      const segs    = Math.round(summary.duration);
      const horas   = Math.floor(segs/3600);
      const mins    = Math.floor((segs%3600)/60);
      kmCalculados  = km * 2;
      const rendimiento = parseFloat(document.getElementById('rendimiento').value) || 12;
      const precioGas   = parseFloat(document.getElementById('precioGas').value)   || 24.5;
      costoGasCalc = (kmCalculados / rendimiento) * precioGas;
      document.getElementById('resKm').textContent       = `${km} km`;
      document.getElementById('resTiempo').textContent   = `${horas}h ${mins}min`;
      document.getElementById('resLitros').textContent   = `${(kmCalculados/rendimiento).toFixed(1)} L`;
      document.getElementById('resCostoGas').textContent = fmt(costoGasCalc);
      document.getElementById('rutaResult').classList.add('show');
      // Google Maps link
      const mapsUrl = `https://www.google.com/maps/dir/${encodeURIComponent(origen)}/${encodeURIComponent(destino)}`;
      const bm = document.getElementById('btnMaps');
      bm.href = mapsUrl; bm.classList.add('show');
      // Waze link
      const wazeUrl = `https://waze.com/ul?q=${encodeURIComponent(destino)}&navigate=yes`;
      const bw = document.getElementById('btnWaze');
      bw.href = wazeUrl; bw.classList.add('show');
      recalcular();
    } catch(e) {
      errEl.style.display = 'block';
      errEl.textContent   = '⚠️ ' + (e.message || 'Error al calcular. Intenta con nombre de ciudad completo.');
    } finally {
      document.getElementById('btnRuta').disabled = false;
      document.getElementById('spinnerRuta').classList.remove('show');
      document.getElementById('btnRutaText').textContent = '📍 Calcular ruta automáticamente';
    }
  }

  // ── VALIDAR HOSPEDAJE ────────────────────────────────────
  function validarHospedaje() {
    const v   = parseFloat(document.getElementById('hospedaje').value) || 0;
    const err = document.getElementById('errHosp');
    if (v > 0 && (v < 900 || v > 1100)) {
      err.style.display = 'block';
      document.getElementById('hospedaje').style.borderColor = 'var(--danger)';
    } else {
      err.style.display = 'none';
      document.getElementById('hospedaje').style.borderColor = 'var(--border)';
    }
  }

  // ── TRANSPORTE LOCAL ─────────────────────────────────────
  function agregarTransporte() {
    transporteCount++;
    const id  = transporteCount;
    const div = document.createElement('div');
    div.className = 'transporte-item';
    div.id = `transporte_${id}`;
    div.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:13px;font-weight:700;color:var(--accent2)">🚕 Viaje #${id}</span>
        <button onclick="eliminarTransporte(${id})" style="background:none;border:none;color:var(--danger);font-size:18px;cursor:pointer;">✕</button>
      </div>
      <div class="row2">
        <div>
          <label>Tipo</label>
          <select onchange="recalcular()">
            <option>Uber</option>
            <option>Taxi</option>
          </select>
        </div>
        <div>
          <label>Monto ($)</label>
          <input type="number" class="transMonto" value="0" min="0" step="10" oninput="recalcular()">
        </div>
      </div>
      <label>Motivo del uso</label>
      <input type="text" class="transMotivo" placeholder="Ej: Traslado al cliente, aeropuerto...">
    `;
    document.getElementById('transporteContainer').appendChild(div);
    recalcular();
  }

  function eliminarTransporte(id) {
    const el = document.getElementById(`transporte_${id}`);
    if (el) { el.remove(); recalcular(); }
  }

  function totalTransporte() {
    let total = 0;
    document.querySelectorAll('.transMonto').forEach(el => { total += parseFloat(el.value) || 0; });
    return total;
  }

  function resumenTransporte() {
    const items = document.querySelectorAll('.transporte-item');
    if (!items.length) return '—';
    return `${items.length} viaje(s)`;
  }

  // ── RECALCULAR ───────────────────────────────────────────
  function recalcular() {
    const personas    = parseInt(document.getElementById('personas').value)       || 1;
    const dias        = parseInt(document.getElementById('dias').value)            || 1;
    const desayuno    = parseFloat(document.getElementById('desayuno').value)      || 0;
    const comida      = parseFloat(document.getElementById('comida').value)        || 0;
    const cena        = parseFloat(document.getElementById('cena').value)          || 0;
    const hospXpers   = parseFloat(document.getElementById('hospedaje').value)     || 0;
    const estacion    = parseFloat(document.getElementById('estacionamiento').value) || 0;
    const imprevistos = parseFloat(document.getElementById('imprevistos').value)   || 0;
    const numCasetas  = parseInt(document.getElementById('numCasetas').value)      || 0;
    const precioCas   = parseFloat(document.getElementById('precioCaseta').value)  || 0;
    const noches      = Math.max(dias - 1, 0);

    // Actualizar campo noches
    document.getElementById('noches').value = noches;

    if (kmCalculados > 0) {
      const rendimiento = parseFloat(document.getElementById('rendimiento').value) || 12;
      const precioGas   = parseFloat(document.getElementById('precioGas').value)   || 24.5;
      costoGasCalc = (kmCalculados / rendimiento) * precioGas;
      document.getElementById('resCostoGas').textContent = fmt(costoGasCalc);
      document.getElementById('resLitros').textContent   = `${(kmCalculados/rendimiento).toFixed(1)} L`;
    }

    const totalCasetas   = numCasetas * precioCas * 2;
    const alim           = (desayuno + comida + cena) * personas * dias;
    const hosp           = hospXpers * personas * noches;
    const est            = estacion * dias;
    const imp            = imprevistos * dias;
    const trans          = totalTransporte();
    const gas            = costoGasCalc;
    const total          = gas + totalCasetas + alim + hosp + est + imp + trans;

    // Desglose
    document.getElementById('descGas').textContent       = kmCalculados > 0 ? `${kmCalculados} km ida y vuelta` : 'Calcula la ruta primero';
    document.getElementById('montoGas').textContent      = gas > 0 ? fmt(gas) : '$—';
    document.getElementById('descCasetas').textContent   = `${numCasetas} caseta(s) × ${fmt(precioCas)} × 2 viajes`;
    document.getElementById('montoCasetas').textContent  = fmt(totalCasetas);
    document.getElementById('descAlim').textContent      = `${personas} persona(s) × ${dias} día(s) · $250 c/u · sujeto a deducibilidad`;
    document.getElementById('montoAlim').textContent     = fmt(alim);
    document.getElementById('descHospDesg').textContent  = `${personas} persona(s) × ${noches} noche(s) · ${fmt(hospXpers)}/noche`;
    document.getElementById('montoHosp').textContent     = fmt(hosp);
    document.getElementById('descTransporte').textContent = resumenTransporte();
    document.getElementById('montoTransporte').textContent = fmt(trans);
    document.getElementById('descEst').textContent       = `${dias} día(s)`;
    document.getElementById('montoEst').textContent      = fmt(est);
    document.getElementById('descImp').textContent       = `${dias} día(s)`;
    document.getElementById('montoImp').textContent      = fmt(imp);

    document.getElementById('totalGeneral').textContent    = total > 0 ? fmt(total) : '$—';
    document.getElementById('totalPorPersona').textContent = total > 0 && personas > 0 ? `${fmt(total/personas)} por persona` : '';
  }

  // ── DATOS COMPLETOS ──────────────────────────────────────
  function getDatos() {
    const personas    = parseInt(document.getElementById('personas').value)       || 1;
    const dias        = parseInt(document.getElementById('dias').value)            || 1;
    const desayuno    = parseFloat(document.getElementById('desayuno').value)      || 0;
    const comida      = parseFloat(document.getElementById('comida').value)        || 0;
    const cena        = parseFloat(document.getElementById('cena').value)          || 0;
    const hospXpers   = parseFloat(document.getElementById('hospedaje').value)     || 0;
    const estacion    = parseFloat(document.getElementById('estacionamiento').value) || 0;
    const imprevistos = parseFloat(document.getElementById('imprevistos').value)   || 0;
    const numCasetas  = parseInt(document.getElementById('numCasetas').value)      || 0;
    const precioCas   = parseFloat(document.getElementById('precioCaseta').value)  || 0;
    const noches      = Math.max(dias - 1, 0);
    const totalCasetas = numCasetas * precioCas * 2;
    const alim        = (desayuno + comida + cena) * personas * dias;
    const hosp        = hospXpers * personas * noches;
    const est         = estacion * dias;
    const imp         = imprevistos * dias;
    const trans       = totalTransporte();
    const total       = costoGasCalc + totalCasetas + alim + hosp + est + imp + trans;
    return {
      area: document.getElementById('area').value,
      solicitante: document.getElementById('solicitante').value,
      trabajador: document.getElementById('trabajador').value,
      fechaInicio: document.getElementById('fechaInicio').value,
      fechaFin: document.getElementById('fechaFin').value,
      tipoServicio: document.getElementById('tipoServicio').value,
      cliente: document.getElementById('cliente').value,
      observaciones: document.getElementById('observaciones').value,
      banco: document.getElementById('banco').value,
      sucursal: document.getElementById('sucursal').value,
      tarjeta: document.getElementById('tarjeta').value,
      clabe: document.getElementById('clabe').value,
      origen: document.getElementById('origen').value,
      destino: document.getElementById('destino').value,
      km: kmCalculados, personas, dias, noches,
      numCasetas, precioCas,
      gasolina: costoGasCalc, casetas: totalCasetas,
      alimentacion: alim, hospedaje: hosp,
      estacionamiento: est, imprevistos: imp,
      transporte: trans, total,
      fecha: new Date().toLocaleDateString('es-MX')
    };
  }

  // ── GENERAR PDF ──────────────────────────────────────────
  function generarPDF() {
    if (kmCalculados === 0) { toast('Calcula la ruta primero', 'err'); return; }
    const d = getDatos();
    if (!d.solicitante) { toast('Escribe el nombre del solicitante', 'err'); return; }

    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit:'mm', format:'letter' });
    const azul=[26,16,128], azulC=[173,216,230], blanco=[255,255,255],
          negro=[0,0,0], amarillo=[255,255,0], gris=[245,245,245];
    const W=215.9, M=10;
    let y=10;

    // Header
    doc.setFillColor(...azul);
    doc.rect(M, y, 35, 22, 'F');
    doc.setTextColor(...blanco);
    doc.setFontSize(18); doc.setFont('helvetica','bold');
    doc.text('MD', M+17.5, y+14, {align:'center'});
    doc.setFontSize(8);
    doc.text('M Dreieck', M+17.5, y+20, {align:'center'});

    doc.setTextColor(...negro);
    doc.setFontSize(14); doc.setFont('helvetica','bold');
    doc.text('Formato-Solicitud para pago de viaticos', W/2+10, y+9, {align:'center'});
    doc.setFontSize(9); doc.setFont('helvetica','normal');
    doc.text('M Dreieck S.A. de C.V.', W/2+10, y+15, {align:'center'});

    doc.setFillColor(...amarillo);
    doc.rect(155, y, 50, 8, 'F');
    doc.setFontSize(8); doc.setFont('helvetica','bold');
    doc.text('FOLIO: ' + d.fecha.replace(/\//g,'-'), 180, y+5.5, {align:'center'});

    y += 28;

    function fila(label, valor, x, w, fy, h=8, lw=50) {
      doc.setFillColor(...azulC);
      doc.rect(x, fy, lw, h, 'F');
      doc.setFillColor(...blanco);
      doc.rect(x+lw, fy, w-lw, h, 'F');
      doc.setDrawColor(180,180,200);
      doc.rect(x, fy, w, h);
      doc.setFont('helvetica','bold'); doc.setFontSize(7.5); doc.setTextColor(...negro);
      doc.text(String(label), x+2, fy+5.5);
      doc.setFont('helvetica','normal');
      doc.text(String(valor||'—').substring(0,55), x+lw+2, fy+5.5);
    }

    const fw = W - M*2;
    const hw = fw/2 - 1;

    fila('Area Solicitante:', d.area, M, fw, y, 8, 45); y+=9;
    fila('Nombre de quien solicita:', d.solicitante, M, hw, y, 8, 52);
    fila('Banco:', d.banco, M+hw+2, hw, y, 8, 20); y+=9;
    fila('Nombre del trabajador:', d.trabajador, M, hw, y, 10, 52);
    fila('No. Tarjeta:', d.tarjeta, M+hw+2, hw, y, 10, 20); y+=11;
    fila('Fecha inicio:', d.fechaInicio, M, hw, y, 8, 30);
    fila('CLABE:', d.clabe, M+hw+2, hw, y, 8, 20); y+=9;
    fila('Fecha fin:', d.fechaFin, M, hw, y, 8, 30);
    fila('Sucursal:', d.sucursal, M+hw+2, hw, y, 8, 20); y+=9;
    fila('Total de dias:', d.dias, M, hw, y, 8, 30); y+=9;
    fila('Tipo de servicio:', d.tipoServicio, M, fw, y, 10, 40); y+=11;
    fila('Nombre del cliente:', d.cliente, M, fw, y, 8, 40); y+=9;
    fila('Ruta:', `${d.origen} -> ${d.destino} (${d.km} km ida y vuelta)`, M, fw, y, 8, 20); y+=9;
    fila('Observaciones:', d.observaciones, M, fw, y, 14, 35); y+=16;

    // Tabla costos
    doc.setFillColor(...azul);
    doc.rect(M, y, fw, 8, 'F');
    doc.setTextColor(...blanco); doc.setFont('helvetica','bold'); doc.setFontSize(9);
    doc.text('DESGLOSE DE VIATICOS', W/2, y+5.5, {align:'center'}); y+=9;

    const rows = [
      ['Gasolina (ida y vuelta)', `${d.km} km · $${(parseFloat(document.getElementById('precioGas').value)||24.5).toFixed(2)}/L`, d.gasolina],
      ['Casetas', `${d.numCasetas} caseta(s) x $${d.precioCas} x 2 viajes`, d.casetas],
      ['Alimentacion', `${d.personas} persona(s) x ${d.dias} dia(s) · sujeto a deducibilidad`, d.alimentacion],
      ['Hospedaje', `${d.personas} persona(s) x ${d.noches} noche(s)`, d.hospedaje],
      ['Transporte local (Uber/Taxi)', resumenTransporte(), d.transporte],
      ['Estacionamiento', `${d.dias} dia(s)`, d.estacionamiento],
      ['Imprevistos / varios', `${d.dias} dia(s)`, d.imprevistos],
    ];

    rows.forEach(([label, desc, monto], i) => {
      const bg = i%2===0 ? blanco : gris;
      doc.setFillColor(...bg);
      doc.rect(M, y, fw, 8, 'F');
      doc.setDrawColor(200,200,210); doc.rect(M, y, fw, 8);
      doc.setTextColor(...negro); doc.setFont('helvetica','bold'); doc.setFontSize(8);
      doc.text(label, M+3, y+5.5);
      doc.setFont('helvetica','normal'); doc.setFontSize(7.5);
      doc.text(desc, M+65, y+5.5);
      doc.setFont('helvetica','bold'); doc.setFontSize(8);
      doc.text(fmt(monto), W-M-3, y+5.5, {align:'right'}); y+=9;
    });

    doc.setFillColor(...azul);
    doc.rect(M, y, fw, 10, 'F');
    doc.setTextColor(...blanco); doc.setFont('helvetica','bold'); doc.setFontSize(11);
    doc.text('TOTAL A DISPERSAR', M+5, y+6.5);
    doc.text(fmt(d.total), W-M-3, y+6.5, {align:'right'}); y+=13;

    doc.setTextColor(...negro); doc.setFontSize(9); doc.setFont('helvetica','normal');
    doc.text(`Total por persona: ${fmt(d.total/d.personas)}`, W-M-3, y, {align:'right'}); y+=14;

    // Firmas
    [[M,'Solicitante'],[M+75,'Autoriza'],[M+155,'Vo.Bo. Finanzas']].forEach(([x,label]) => {
      doc.setDrawColor(...negro);
      doc.line(x, y+10, x+50, y+10);
      doc.setFontSize(8); doc.text(label, x+25, y+15, {align:'center'});
    });
    y+=20;

    doc.setFontSize(7); doc.setTextColor(150,150,150);
    doc.text(`Generado: ${new Date().toLocaleString('es-MX')} · Sistema M Dreieck`, W/2, y+5, {align:'center'});

    const nombre = `Viaticos_${(d.trabajador||'MD').replace(/\s/g,'_')}_${d.fechaInicio||d.fecha}.pdf`;
    doc.save(nombre);
    toast('✅ PDF generado correctamente', 'ok');
    return doc;
  }

  // ── ENVIAR CORREO ────────────────────────────────────────
  async function enviarCorreo() {
    if (kmCalculados === 0) { toast('Calcula la ruta primero', 'err'); return; }
    const d = getDatos();
    if (!d.solicitante) { toast('Escribe el nombre del solicitante', 'err'); return; }
    const correo = document.getElementById('correoDestino').value.trim();
    if (!correo) { toast('Escribe el correo destino', 'err'); return; }
    generarPDF();
    const btn = document.getElementById('btnEmail');
    btn.disabled = true; btn.textContent = 'Enviando…';
    try {
      await fetch(SHEETS_URL, {
        method:'POST', mode:'no-cors',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ accion:'email', correoDestino:correo, remitente:REMITENTE, ...d,
          gasolina:d.gasolina.toFixed(2), casetas:d.casetas.toFixed(2),
          alimentacion:d.alimentacion.toFixed(2), hospedaje:d.hospedaje.toFixed(2),
          estacionamiento:d.estacionamiento.toFixed(2), imprevistos:d.imprevistos.toFixed(2),
          transporte:d.transporte.toFixed(2), total:d.total.toFixed(2) })
      });
      toast('✅ PDF descargado · correo enviado', 'ok');
    } catch(e) {
      toast('⚠️ PDF listo, revisa el correo', 'err');
    } finally {
      btn.disabled = false; btn.textContent = '📧 Generar PDF y enviar por correo';
    }
  }

  // ── GUARDAR SHEETS ───────────────────────────────────────
  async function guardarEnSheets() {
    if (kmCalculados === 0) { toast('Calcula la ruta primero', 'err'); return; }
    const d = getDatos();
    if (!d.solicitante) { toast('Escribe el nombre del solicitante', 'err'); return; }
    const btn = document.getElementById('btnGuardar');
    btn.disabled = true; btn.textContent = 'Guardando…';
    try {
      await fetch(SHEETS_URL, {
        method:'POST', mode:'no-cors',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ accion:'sheets', ...d,
          gasolina:d.gasolina.toFixed(2), casetas:d.casetas.toFixed(2),
          alimentacion:d.alimentacion.toFixed(2), hospedaje:d.hospedaje.toFixed(2),
          estacionamiento:d.estacionamiento.toFixed(2), imprevistos:d.imprevistos.toFixed(2),
          transporte:d.transporte.toFixed(2), total:d.total.toFixed(2) })
      });
      toast('✅ Guardado en Google Sheets', 'ok');
      btn.textContent = '✅ Guardado';
    } catch(e) {
      toast('❌ Error al guardar', 'err');
      btn.disabled = false; btn.textContent = '✅ Guardar en Google Sheets';
    }
  }

  // ── HELPERS ──────────────────────────────────────────────
  function fmt(n) {
    return '$' + Number(n).toLocaleString('es-MX', {minimumFractionDigits:2, maximumFractionDigits:2});
  }
  function toast(msg, type='ok') {
    const el = document.getElementById('toast');
    el.textContent = msg; el.className = `show ${type}`;
    setTimeout(() => { el.className=''; }, 3500);
  }

  document.addEventListener('DOMContentLoaded', () => {
    recalcular();
    ['rendimiento','precioGas','estacionamiento','imprevistos'].forEach(id => {
      document.getElementById(id).addEventListener('input', recalcular);
    });
    const hoy = new Date().toISOString().split('T')[0];
    document.getElementById('fechaInicio').value = hoy;
    document.getElementById('fechaFin').value = hoy;
  });
</script>
</body>
</html>
